# Systemix environment — copy to .env.local and fill in. Never commit real keys.
# Full setup runbook: docs/feature/posthog-loop/setup.md

# ── PostHog capture (browser; ships to the client bundle) ──────────────────────
# Public Project API key (starts phc_). Without it, the live site captures nothing.
NEXT_PUBLIC_POSTHOG_KEY=
# EU ingestion host (use https://us.i.posthog.com only if you chose the US region).
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── PostHog server queries (evidence pull / watch / scheduled sync) ────────────
# Personal API key (starts phx_) — read/query scope. NOT the public key above.
POSTHOG_API_KEY=
# Numeric project id (project settings, or the dashboard URL /project/<ID>).
POSTHOG_PROJECT_ID=
# EU API host for server-side queries.
POSTHOG_HOST=https://eu.posthog.com

# ── Hermes synthesis (optional; local Ollama) ─────────────────────────────────
# The automated loop summarizes real numbers deterministically without this.
# Set these to upgrade local runs to real LLM synthesis.
OLLAMA_URL=http://localhost:11434
HERMES_MODEL=hermes3
